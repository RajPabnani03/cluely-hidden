# Local signing env — copy to signing.env and fill in. NEVER commit signing.env.
# source scripts/signing.env before npm run tauri:build

# export APPLE_ID="you@email.com"
# export APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"  # app-specific password
# export APPLE_TEAM_ID="XXXXXXXXXX"

# Or API key route (see Tauri macOS docs):
# export APPLE_API_KEY="..."
# export APPLE_API_ISSUER="..."
# export APPLE_API_KEY_PATH="$HOME/private_keys/AuthKey_XXX.p8"